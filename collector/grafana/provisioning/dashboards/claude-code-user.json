{
  "uid": "claude-code-per-developer",
  "title": "Claude Code - Per Developer",
  "tags": ["claude-code", "otel", "per-developer"],
  "timezone": "browser",
  "refresh": "5m",
  "schemaVersion": 39,
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "developer",
        "label": "Developer",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "developer", "stream": "{service_name=\"claude-code\"}", "type": 1 },
        "includeAll": false,
        "current": {},
        "refresh": 2,
        "multi": false
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "model", "stream": "{service_name=\"claude-code\"}", "type": 1 },
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "Summary",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": [],
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | developer=~\"$developer\" | model=~\"$model\" | unwrap cost_usd [$__range]))",
        "legendFormat": "Cost",
        "queryType": "instant"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Sessions",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "count(sum by (session_id) (count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__range])))",
        "legendFormat": "Sessions",
        "queryType": "instant"
      }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Prompts",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum(count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__range]))",
        "legendFormat": "Prompts",
        "queryType": "instant"
      }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "steps": [{ "color": "purple", "value": null }] }
        }
      }
    },
    {
      "id": 4,
      "title": "API Errors",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"api_error\" | developer=~\"$developer\" [$__range]))",
        "legendFormat": "Errors",
        "queryType": "instant"
      }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },

    {
      "id": 101,
      "title": "Cost",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "panels": [],
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Cost Over Time by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum by (model) (sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | developer=~\"$developer\" | model=~\"$model\" | unwrap cost_usd [$__interval]))",
        "legendFormat": "{{model}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 11,
      "title": "Cost by Model",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum by (model) (sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | developer=~\"$developer\" | model=~\"$model\" | unwrap cost_usd [$__range]))",
        "legendFormat": "{{model}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },

    {
      "id": 102,
      "title": "Activity",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "panels": [],
      "collapsed": false
    },
    {
      "id": 20,
      "title": "Prompts Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum(count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__interval]))",
        "legendFormat": "Prompts"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 21,
      "title": "API Errors Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "count by (status_code) (count_over_time({service_name=\"claude-code\"} | event_name=\"api_error\" | developer=~\"$developer\" [$__interval]))",
        "legendFormat": "{{status_code}}"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          }
        }
      }
    }
  ]
}
