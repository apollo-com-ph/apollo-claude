{
  "uid": "claude-code-overview",
  "title": "Claude Code Overview",
  "tags": ["claude-code", "otel", "overview"],
  "timezone": "browser",
  "refresh": "5m",
  "schemaVersion": 39,
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "developer",
        "label": "Developer",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "developer", "stream": "{service_name=\"claude-code\"}", "type": 1 },
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "model", "stream": "{service_name=\"claude-code\"}", "type": 1 },
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "KPIs",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": [],
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Active Developers Today",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "count(count by (developer) (count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [24h])))",
        "legendFormat": "Developers",
        "queryType": "instant"
      }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Active Developers This Week",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "count(count by (developer) (count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [7d])))",
        "legendFormat": "Developers",
        "queryType": "instant"
      }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Sessions",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "count(sum by (session_id) (count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__range])))",
        "legendFormat": "Sessions",
        "queryType": "instant"
      }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Prompts",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum(count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__range]))",
        "legendFormat": "Prompts",
        "queryType": "instant"
      }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "steps": [{ "color": "purple", "value": null }] }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | developer=~\"$developer\" | model=~\"$model\" | unwrap cost_usd [$__range]))",
        "legendFormat": "Cost",
        "queryType": "instant"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "API Errors",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"api_error\" | developer=~\"$developer\" [$__range]))",
        "legendFormat": "Errors",
        "queryType": "instant"
      }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Total Tokens",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | developer=~\"$developer\" | model=~\"$model\" | unwrap input_tokens [$__range])) + sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | developer=~\"$developer\" | model=~\"$model\" | unwrap output_tokens [$__range]))",
        "legendFormat": "Tokens",
        "queryType": "instant"
      }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "short",
          "decimals": 0,
          "thresholds": { "steps": [{ "color": "orange", "value": null }] }
        }
      }
    },
    {
      "id": 7,
      "title": "Avg Prompts / Session",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum(count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__range])) / count(sum by (session_id) (count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__range])))",
        "legendFormat": "Prompts/Session",
        "queryType": "instant"
      }],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "decimals": 1,
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 5 },
              { "color": "super-light-green", "value": 15 }
            ]
          }
        }
      }
    },

    {
      "id": 101,
      "title": "Adoption",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "panels": [],
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Daily Active Developers",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "count(sum by (developer) (count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__interval])))",
        "legendFormat": "Active Developers"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 11,
      "title": "Sessions per Day by Developer",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "count by (developer) (sum by (developer, session_id) (count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__interval])))",
        "legendFormat": "{{developer}}"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      }
    },

    {
      "id": 102,
      "title": "Cost",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "panels": [],
      "collapsed": false
    },
    {
      "id": 20,
      "title": "Cost Over Time by Developer",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 21 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum by (developer) (sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | developer=~\"$developer\" | model=~\"$model\" | unwrap cost_usd [$__interval]))",
        "legendFormat": "{{developer}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 21,
      "title": "Cost by Model",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 21 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum by (model) (sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | model=~\"$model\" | unwrap cost_usd [$__range]))",
        "legendFormat": "{{model}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },
    {
      "id": 22,
      "title": "Cost per Developer",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 21 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum by (developer) (sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | developer=~\"$developer\" | model=~\"$model\" | unwrap cost_usd [$__range]))",
        "legendFormat": "{{developer}}"
      }],
      "transformations": [
        { "id": "reduce", "options": { "reducers": ["last"] } },
        { "id": "sortBy", "options": { "sort": [{ "field": "Last", "desc": true }] } }
      ],
      "options": {
        "sortBy": [{ "displayName": "Last", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Field" },
            "properties": [{ "id": "displayName", "value": "Developer" }]
          },
          {
            "matcher": { "id": "byName", "options": "Last" },
            "properties": [{ "id": "displayName", "value": "Cost (USD)" }]
          }
        ]
      }
    },

    {
      "id": 104,
      "title": "Model Analysis",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "panels": [],
      "collapsed": false
    },
    {
      "id": 40,
      "title": "Model Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum by (model) (count_over_time({service_name=\"claude-code\", event_name=\"api_request\"} | model=~\"$model\" [$__interval]))",
        "legendFormat": "{{model}}"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 41,
      "title": "Token Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | developer=~\"$developer\" | model=~\"$model\" | unwrap input_tokens [$__interval]))",
          "legendFormat": "Input"
        },
        {
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | developer=~\"$developer\" | model=~\"$model\" | unwrap output_tokens [$__interval]))",
          "legendFormat": "Output"
        },
        {
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | developer=~\"$developer\" | model=~\"$model\" | unwrap cache_read_tokens [$__interval]))",
          "legendFormat": "Cache Read"
        },
        {
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | developer=~\"$developer\" | model=~\"$model\" | unwrap cache_creation_tokens [$__interval]))",
          "legendFormat": "Cache Creation"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 }
        }
      }
    },

    {
      "id": 103,
      "title": "Engagement",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "panels": [],
      "collapsed": false
    },
    {
      "id": 32,
      "title": "Prompts Over Time by Developer",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum by (developer) (count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__interval]))",
        "legendFormat": "{{developer}}"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 31,
      "title": "Prompts per Developer",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum by (developer) (count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__range]))",
        "legendFormat": "{{developer}}"
      }],
      "transformations": [
        { "id": "reduce", "options": { "reducers": ["last"] } },
        { "id": "sortBy", "options": { "sort": [{ "field": "Last", "desc": true }] } }
      ],
      "options": {
        "sortBy": [{ "displayName": "Last", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Field" },
            "properties": [{ "id": "displayName", "value": "Developer" }]
          },
          {
            "matcher": { "id": "byName", "options": "Last" },
            "properties": [{ "id": "displayName", "value": "Prompts" }]
          }
        ]
      }
    },
    {
      "id": 30,
      "title": "Sessions by Developer",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 47 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "count by (developer) (sum by (developer, session_id) (count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__range])))",
        "legendFormat": "{{developer}}"
      }],
      "transformations": [
        { "id": "reduce", "options": { "reducers": ["last"] } },
        { "id": "sortBy", "options": { "sort": [{ "field": "Last", "desc": true }] } }
      ],
      "options": {
        "sortBy": [{ "displayName": "Last", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Field" },
            "properties": [{ "id": "displayName", "value": "Developer" }]
          },
          {
            "matcher": { "id": "byName", "options": "Last" },
            "properties": [{ "id": "displayName", "value": "Sessions" }]
          }
        ]
      }
    },
    {
      "id": 33,
      "title": "Usage by Repository",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 47 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum by (repository) (count_over_time({service_name=\"claude-code\", event_name=\"user_prompt\"} | developer=~\"$developer\" [$__range]))",
        "legendFormat": "{{repository}}"
      }],
      "transformations": [
        { "id": "reduce", "options": { "reducers": ["last"] } },
        { "id": "sortBy", "options": { "sort": [{ "field": "Last", "desc": true }] } }
      ],
      "options": {
        "sortBy": [{ "displayName": "Last", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Field" },
            "properties": [{ "id": "displayName", "value": "Repository" }]
          },
          {
            "matcher": { "id": "byName", "options": "Last" },
            "properties": [{ "id": "displayName", "value": "Prompts" }]
          }
        ]
      }
    }
  ]
}
